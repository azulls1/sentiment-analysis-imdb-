  "mcpServers": {
    "github": {
      "required": false,
      "description": "GitHub integration for repos, PRs, issues"
    },
    "filesystem": {
      "required": false,
      "description": "Enhanced filesystem access"
    },
    "memory": {
      "required": false,
      "description": "Persistent memory across sessions"
    },
    "postgres": {
      "required": false,
      "description": "PostgreSQL database connection"
    },
    "fetch": {
      "required": false,
      "description": "HTTP requests for external APIs"
    }
  },

  "hooks": {
    "on_init": "hooks/on-init.py",
    "on_agent_switch": "hooks/on-agent-switch.py",
    "on_step_complete": "hooks/on-step-complete.py",
    "on_workflow_complete": "hooks/on-workflow-complete.py"
  },

  "features": {
    "ralph_loop": {
      "enabled": true,
      "max_iterations": 50,
      "description": "Autonomous iterative development loops"
    },
    "code_review": {
      "enabled": true,
      "agents": 5,
      "description": "Automated code review with parallel agents"
    },
    "pr_review": {
      "enabled": true,
      "agents": 6,
      "description": "Comprehensive PR review toolkit"
    },
    "feature_dev": {
      "enabled": true,
      "phases": 5,
      "description": "Guided feature development workflow"
    },
    "hookify": {
      "enabled": true,
      "description": "Custom hooks for project-specific guards"
    },
    "security_guidance": {
      "enabled": true,
      "auto_trigger": true,
      "description": "Automatic security vulnerability monitoring"
    },
    "learning_mode": {
      "enabled": true,
      "description": "Interactive educational development mode"
    },
    "context_management": {
      "enabled": true,
      "sync_with_mcp": true,
      "description": "Context management between sessions"
    },
    "changelog_generation": {
      "enabled": true,
      "format": "keep-a-changelog",
      "description": "Automatic changelog generation from commits"
    }
  },

  "requirements": {
    "claude_code": ">=1.0.0",
    "python": ">=3.10",
    "node": ">=20.0.0"
  },

  "keywords": [
    "ai-development",
    "multi-agent",
    "bmad",
    "agile",
    "claude-code",
    "ralph-loop",
    "autonomous-development"
  ]
