# Auto-detect text files and normalize line endings
* text=auto

# Force LF line endings for source files
*.py text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.env.example text eol=lf
nginx.conf text eol=lf

# Binary files (do not normalize)
*.joblib binary
*.pkl binary
*.h5 binary
*.pt binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary

# Linguist overrides - mark non-project files as vendored
forest-design-system/** linguist-vendored
frontend/node_modules/** linguist-vendored
