# ==============================================================
# Environment Variables - IMDb Sentiment Analysis
# ==============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Markers: [REQUIRED] = must be set, [OPTIONAL] = has sensible default
# ==============================================================

# ========================
# Redis & Celery [OPTIONAL]
# ========================
# URL for Redis instance used by Celery task queue
# Default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Celery broker URL (typically same as REDIS_URL)
# Default: redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# ========================
# CORS [OPTIONAL]
# ========================
# Comma-separated list of allowed frontend origins
# Default: http://localhost:4200
CORS_ORIGINS=http://localhost:4200,https://imdb-sentiment.iagentek.com.mx

# ========================
# Supabase [REQUIRED for cloud DB]
# ========================
# Your Supabase project URL (found in Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (safe for frontend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CHANGE_ME

# Supabase service role key (server-side only, NEVER expose to frontend)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CHANGE_ME_SERVICE

# ========================
# API Security [OPTIONAL]
# ========================
# API key for authenticating external requests to protected endpoints
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me-to-a-random-token

# ========================
# ML Reproducibility [OPTIONAL]
# ========================
# Random seed for reproducible model training results
# Default: 42
RANDOM_SEED=42

# ========================
# Application [OPTIONAL]
# ========================
# Application environment (development | staging | production)
# Default: development
APP_ENV=development

# Log level (DEBUG | INFO | WARNING | ERROR)
# Default: INFO
LOG_LEVEL=INFO

# ========================
# Monitoring [OPTIONAL]
# ========================
# Sentry DSN for error tracking. Leave empty to disable.
# Get your DSN from https://sentry.io/
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
